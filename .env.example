# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# --- Supabase (frontend form submissions) ---
# Both keys are safe to expose to the browser; the database is locked down with
# INSERT-only Row-Level-Security policies for anon.
# Leave unset to use the bundled defaults in src/lib/supabase.ts.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
