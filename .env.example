# Local example environment variables
# For Neon / Postgres, set DATABASE_URL as provided by Neon (or Vercel secret).
DATABASE_URL=postgresql://<username>:<password>@<host>:<port>/<database>?sslmode=require

# Optional: migrate automatically on start (not recommended on production)
# MIGRATE_ON_START=true
# Supabase / Neon Postgres (server-side - KEEP SECRET)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase / Neon (client-side - public anon key for direct inserts)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Optional: local database path (defaults to data.db)
# DB_PATH=data.db

# Node environment
# NODE_ENV=production

# Server port (defaults to 3000)
# PORT=3000
