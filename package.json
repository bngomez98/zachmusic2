  "description": "music aistudio",
  "homepage": "https://zacharywalkermusic.com",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs --external:framer-motion --external:motion",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "migrate": "node scripts/migrate.js",
    "vercel": "vercel",
    "vercel:dev": "vercel dev",
    "deploy": "vercel --prod"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
