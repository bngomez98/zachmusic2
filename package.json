    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.10.0",
    "react": "^19.0.1",
    "resend": "^4.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^22.14.0",
